{
  "name": "AgentInsight",
  "type": "object",
  "properties": {
    "organization_id": {
      "type": "string",
      "description": "ID du groupe (partage entre membres)"
    },
    "categorie": {
      "type": "string",
      "enum": [
        "tendance_marche",
        "performance_joueur",
        "opportunite_transfert",
        "analyse_equipe",
        "prevision"
      ],
      "description": "Catégorie d'insight"
    },
    "titre": {
      "type": "string",
      "description": "Titre de l'insight"
    },
    "contenu": {
      "type": "string",
      "description": "Contenu détaillé de l'insight"
    },
    "donnees_source": {
      "type": "string",
      "description": "Données sources utilisées"
    },
    "confiance": {
      "type": "number",
      "description": "Score de confiance (0-100)"
    },
    "player_ids": {
      "type": "string",
      "description": "IDs des joueurs concernés (séparés par virgules)"
    },
    "priority": {
      "type": "string",
      "enum": [
        "haute",
        "moyenne",
        "basse"
      ],
      "default": "moyenne",
      "description": "Niveau de priorité"
    }
  },
  "required": [
    "categorie",
    "titre",
    "contenu"
  ],
  "rls": {
    "create": {
      "created_by_id": "{{user.id}}"
    },
    "read": {
      "$or": [
        {
          "created_by_id": "{{user.id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        },
        {
          "$and": [
            {
              "data.organization_id": "{{user.data.organization_id}}"
            },
            {
              "data.organization_id": {
                "$ne": null
              }
            }
          ]
        }
      ]
    },
    "update": {
      "$or": [
        {
          "created_by_id": "{{user.id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        },
        {
          "$and": [
            {
              "data.organization_id": "{{user.data.organization_id}}"
            },
            {
              "data.organization_id": {
                "$ne": null
              }
            }
          ]
        }
      ]
    },
    "delete": {
      "$or": [
        {
          "created_by_id": "{{user.id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        },
        {
          "$and": [
            {
              "data.organization_id": "{{user.data.organization_id}}"
            },
            {
              "data.organization_id": {
                "$ne": null
              }
            }
          ]
        }
      ]
    }
  }
}
