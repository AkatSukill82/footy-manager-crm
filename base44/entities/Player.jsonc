      "description": "Matchs en \u00e9quipe nationale"
    },
    "buts_international": {
      "type": "number",
      "description": "Buts en \u00e9quipe nationale"
    },
    "passes_international": {
      "type": "number",
      "description": "Passes d\u00e9cisives en \u00e9quipe nationale"
