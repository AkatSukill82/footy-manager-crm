{
  "name": "Player",
  "type": "object",
  "properties": {
    "organization_id": {
      "type": "string",
      "description": "ID du groupe (partage entre membres)"
    },
    "nom": {
      "type": "string",
      "description": "Nom complet du joueur"
    },
    "age": {
      "type": "number",
      "description": "\u00c2ge du joueur"
    },
    "date_naissance": {
      "type": "string",
      "format": "date",
      "description": "Date de naissance"
    },
    "lieu_naissance": {
      "type": "string",
      "description": "Ville / pays de naissance"
    },
    "poste": {
      "type": "string",
      "enum": [
        "Gardien",
        "D\u00e9fenseur central",
        "Lat\u00e9ral droit",
        "Lat\u00e9ral gauche",
        "Milieu d\u00e9fensif",
        "Milieu central",
        "Milieu offensif",
        "Ailier droit",
        "Ailier gauche",
        "Attaquant"
      ],
      "description": "Poste principal"
    },
    "poste_secondaire": {
      "type": "string",
      "enum": [
        "Gardien",
        "D\u00e9fenseur central",
        "Lat\u00e9ral droit",
        "Lat\u00e9ral gauche",
        "Milieu d\u00e9fensif",
        "Milieu central",
        "Milieu offensif",
        "Ailier droit",
        "Ailier gauche",
        "Attaquant"
      ],
      "description": "Poste secondaire"
    },
    "nationalite": {
      "type": "string",
      "description": "Nationalit\u00e9 principale"
    },
    "nationalite_secondaire": {
      "type": "string",
      "description": "Deuxi\u00e8me nationalit\u00e9"
    },
    "club_actuel": {
      "type": "string",
      "description": "Club actuel"
    },
    "email": {
      "type": "string",
      "description": "Email du joueur"
    },
    "telephone": {
      "type": "string",
      "description": "Num\u00e9ro de t\u00e9l\u00e9phone du joueur"
    },
    "instagram": {
      "type": "string",
      "description": "Compte Instagram (@handle)"
    },
    "twitter": {
      "type": "string",
      "description": "Compte Twitter/X (@handle)"
    },
    "linkedin": {
      "type": "string",
      "description": "Profil LinkedIn"
    },
    "whatsapp": {
      "type": "string",
      "description": "Num\u00e9ro WhatsApp"
    },
    "adresse": {
      "type": "string",
      "description": "Adresse personnelle"
    },
    "ville_residence": {
      "type": "string",
      "description": "Ville de r\u00e9sidence"
    },
    "pays_residence": {
      "type": "string",
      "description": "Pays de r\u00e9sidence"
    },
    "valeur_marchande": {
      "type": "number",
      "description": "Valeur marchande en millions d'euros (Transfermarkt)"
    },
    "valeur_marchande_peak": {
      "type": "number",
      "description": "Valeur marchande maximale atteinte en carri\u00e8re (M\u20ac)"
    },
    "pied_fort": {
      "type": "string",
      "enum": [
        "Droit",
        "Gauche",
        "Les deux"
      ],
      "description": "Pied fort"
    },
    "taille": {
      "type": "number",
      "description": "Taille en cm"
    },
    "poids": {
      "type": "number",
      "description": "Poids en kg"
    },
    "contrat_fin": {
      "type": "string",
      "format": "date",
      "description": "Date de fin de contrat"
    },
    "en_pret": {
      "type": "boolean",
      "description": "Le joueur est actuellement en prêt"
    },
    "club_proprietaire": {
      "type": "string",
      "description": "Club propriétaire (qui détient le joueur et l'a prêté)"
    },
    "pret_fin": {
      "type": "string",
      "format": "date",
      "description": "Date de fin du prêt"
    },
    "date_arrivee_club": {
      "type": "string",
      "format": "date",
      "description": "Date d'arrivée au club actuel (Transfermarkt « Joined »)"
    },
    "option_contrat": {
      "type": "string",
      "description": "Option de contrat (ex: option +1 an) — Transfermarkt"
    },
    "photo_url": {
      "type": "string",
      "description": "URL de la photo du joueur"
    },
    "salaire": {
      "type": "number",
      "description": "Salaire annuel en millions d'euros"
    },
    "salaire_semaine": {
      "type": "number",
      "description": "Salaire hebdomadaire en milliers d'euros"
    },
    "agent": {
      "type": "string",
      "description": "Agent / repr\u00e9sentant"
    },
    "agent_email": {
      "type": "string",
      "description": "Email de l'agent"
    },
    "agent_telephone": {
      "type": "string",
      "description": "T\u00e9l\u00e9phone de l'agent"
    },
    "agence": {
      "type": "string",
      "description": "Agence / cabinet de repr\u00e9sentation"
    },
    "numero_maillot": {
      "type": "number",
      "description": "Num\u00e9ro de maillot"
    },
    "transfermarkt_id": {
      "type": "string",
      "description": "ID Transfermarkt"
    },
    "sofascore_id": {
      "type": "string",
      "description": "ID SofaScore"
    },
    "fotmob_id": {
      "type": "string",
      "description": "ID FotMob"
    },
    "besoccer_id": {
      "type": "string",
      "description": "ID BeSoccer"
    },
    "soccerdonna_id": {
      "type": "string",
      "description": "ID Soccerdonna (football féminin)"
    },
    "sexe": {
      "type": "string",
      "enum": ["Masculin", "Féminin"],
      "description": "Sexe du joueur (Féminin = source Soccerdonna)"
    },
    "coach": {
      "type": "string",
      "description": "Entra\u00eeneur principal actuel"
    },
    "manager": {
      "type": "string",
      "description": "Manager / Directeur sportif du club"
    },
    "stade": {
      "type": "string",
      "description": "Stade du club actuel"
    },
    "ligue": {
      "type": "string",
      "description": "Ligue / championnat actuel"
    },
    "pays_ligue": {
      "type": "string",
      "description": "Pays de la ligue actuelle"
    },
    "matchs_joues": {
      "type": "number",
      "description": "Matchs jou\u00e9s (saison en cours)"
    },
    "titularisations": {
      "type": "number",
      "description": "Titularisations (saison en cours)"
    },
    "minutes_jouees": {
      "type": "number",
      "description": "Minutes jou\u00e9es (saison en cours)"
    },
    "buts": {
      "type": "number",
      "description": "Buts (saison en cours)"
    },
    "passes_decisives": {
      "type": "number",
      "description": "Passes d\u00e9cisives (saison en cours)"
    },
    "buts_passes": {
      "type": "number",
      "description": "Buts + Passes d\u00e9cisives (saison)"
    },
    "cartons_jaunes": {
      "type": "number",
      "description": "Cartons jaunes (saison en cours)"
    },
    "cartons_rouges": {
      "type": "number",
      "description": "Cartons rouges (saison en cours)"
    },
    "note_moyenne": {
      "type": "number",
      "description": "Note SofaScore moyenne (saison en cours)"
    },
    "xg": {
      "type": "number",
      "description": "Expected Goals \u2013 xG (saison)"
    },
    "xa": {
      "type": "number",
      "description": "Expected Assists \u2013 xA (saison)"
