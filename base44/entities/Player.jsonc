      "description": "D\u00e9gagements (saison \u2013 d\u00e9fenseurs)"
    },
    "fautes_commises": {
      "type": "number",
      "description": "Fautes commises (saison)"
    },
    "fautes_subies": {
      "type": "number",
      "description": "Fautes subies (saison)"
    },
    "hors_jeu": {
      "type": "number",
      "description": "Fois hors-jeu (saison)"
    },
